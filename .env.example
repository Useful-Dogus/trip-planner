# Supabase (https://supabase.com)
# Project Settings → API → Project URL (서버/클라이언트 공용)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Project Settings → API → anon public key (클라이언트/SSR Auth 용)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Project Settings → API → service_role key (서버 전용, 비밀)
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase Dashboard 사전 설정 (필수)
# - Authentication → Providers → Email 활성화
# - Authentication → URL Configuration → Site URL/Redirect URLs 에
#   http://localhost:3000 및 운영 도메인 등록
