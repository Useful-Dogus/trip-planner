# Supabase (https://supabase.com)
# Project Settings → General → Project ID 를 포함한 URL
SUPABASE_URL=https://your-project-id.supabase.co
# Project Settings → API → Service Role Key (서버 데이터 접근용, 비밀)
SUPABASE_SERVICE_KEY=your-service-role-key
# Project Settings → API → anon public key (클라이언트/SSR Auth 용)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Dashboard 사전 설정 (필수)
# - Authentication → Providers → Email 활성화
# - Authentication → URL Configuration → Site URL/Redirect URLs 에
#   http://localhost:3000 및 운영 도메인 등록
